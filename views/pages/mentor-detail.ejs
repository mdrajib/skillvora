<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="page-hero">
  <div class="container" style="position:relative;z-index:1;">
    <div style="display:flex;align-items:center;gap:8px;font-size:0.82rem;color:var(--text-muted);margin-bottom:28px;">
      <a href="/" style="color:var(--text-muted);">Home</a><span>›</span>
      <a href="/mentors" style="color:var(--text-muted);">Mentors</a><span>›</span>
      <span style="color:var(--text-primary);"><%= mentor.name %></span>
    </div>

    <div style="display:grid;grid-template-columns:auto 1fr;gap:40px;align-items:start;max-width:900px;">
      <div style="width:160px;height:160px;border-radius:var(--radius-xl);background:linear-gradient(135deg,var(--deep-nexus),var(--dark-surface));display:flex;align-items:center;justify-content:center;font-size:4rem;border:2px solid var(--dark-border);flex-shrink:0;">👨‍💻</div>
      <div>
        <p class="mentor-expertise" style="font-size:0.85rem;margin-bottom:8px;"><%= mentor.expertise %></p>
        <h1 style="font-size:2.2rem;font-weight:800;font-family:var(--font-display);margin-bottom:8px;"><%= mentor.name %></h1>
        <p style="color:var(--vora-purple);font-weight:600;margin-bottom:16px;"><%= mentor.title %></p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:20px;">
          <span class="badge badge-gray">⏳ <%= mentor.experience %></span>
          <% if (mentor.courses) { %><span class="badge badge-purple"><%= mentor.courses.length %> courses</span><% } %>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <% if (mentor.linkedin) { %><a href="<%= mentor.linkedin %>" target="_blank" class="btn btn-outline btn-sm">LinkedIn ↗</a><% } %>
          <% if (mentor.youtube)  { %><a href="<%= mentor.youtube  %>" target="_blank" class="btn btn-outline btn-sm">YouTube ↗</a><% } %>
          <% if (mentor.website)  { %><a href="<%= mentor.website  %>" target="_blank" class="btn btn-outline btn-sm">Website ↗</a><% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<section class="section">
  <div class="container">
    <div style="display:grid;grid-template-columns:1.5fr 1fr;gap:56px;align-items:start;max-width:1000px;">

      <div>
        <h2 style="font-size:1.4rem;font-weight:700;margin-bottom:20px;">Biography</h2>
        <p style="color:var(--text-muted);line-height:1.9;font-size:0.975rem;margin-bottom:40px;"><%= mentor.bio %></p>

        <% if (mentor.courses && mentor.courses.length) { %>
        <h2 style="font-size:1.4rem;font-weight:700;margin-bottom:20px;">Courses by <%= mentor.name %></h2>
        <div style="display:flex;flex-direction:column;gap:12px;">
          <% mentor.courses.forEach(c => { %>
          <a href="/courses" style="display:flex;align-items:center;gap:16px;background:var(--dark-card);border:1px solid var(--dark-border);border-radius:var(--radius-md);padding:16px 20px;transition:all 0.2s;" onmouseover="this.style.borderColor='rgba(127,119,221,0.3)'" onmouseout="this.style.borderColor='var(--dark-border)'">
            <span style="font-size:1.5rem;">📚</span>
            <span style="font-weight:600;"><%= c %></span>
            <span style="margin-left:auto;color:var(--vora-purple);">→</span>
          </a>
          <% }) %>
        </div>
        <% } %>
      </div>

      <div>
        <div style="background:var(--dark-card);border:1px solid var(--dark-border);border-radius:var(--radius-xl);padding:28px;margin-bottom:20px;">
          <h3 style="font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted);margin-bottom:20px;">Quick Facts</h3>
          <div style="display:flex;flex-direction:column;gap:16px;">
            <div style="display:flex;align-items:center;gap:12px;font-size:0.9rem;">
              <span style="color:var(--vora-purple);">⏳</span>
              <span class="muted">Experience:</span>
              <span style="font-weight:600;margin-left:auto;"><%= mentor.experience %></span>
            </div>
            <div style="display:flex;align-items:center;gap:12px;font-size:0.9rem;">
              <span style="color:var(--skill-teal);">🌐</span>
              <span class="muted">Language:</span>
              <span style="font-weight:600;margin-left:auto;">English & Bangla</span>
            </div>
            <% if (mentor.courses) { %>
            <div style="display:flex;align-items:center;gap:12px;font-size:0.9rem;">
              <span style="color:var(--hunger-amber);">📚</span>
              <span class="muted">Courses:</span>
              <span style="font-weight:600;margin-left:auto;"><%= mentor.courses.length %></span>
            </div>
            <% } %>
          </div>
        </div>
        <a href="/contact?subject=Question for <%= mentor.name %>" class="btn btn-primary" style="width:100%;justify-content:center;">
          Ask a Question →
        </a>
      </div>

    </div>
  </div>
</section>

<%- include('../partials/footer') %>
