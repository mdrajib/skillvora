<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- Hero -->
<div class="page-hero">
  <div class="container" style="position:relative;z-index:1;">
    <span class="section-label">AI Agency</span>
    <h1 class="display-lg" style="margin-bottom:16px;">
      We build AI solutions<br/><span class="gradient-text">that deliver results</span>
    </h1>
    <p class="muted body-lg" style="max-width:560px;margin-bottom:36px;">
      From AI consulting and Odoo ERP implementation to custom software — Skillvora's agency team helps businesses across Bangladesh lead in the digital age.
    </p>
    <div style="display:flex;gap:14px;flex-wrap:wrap;">
      <a href="/contact" class="btn btn-primary btn-lg">Start a Project →</a>
      <a href="#projects" class="btn btn-outline btn-lg">See Our Work</a>
    </div>
  </div>
</div>

<!-- Services -->
<section class="section" style="border-top:1px solid var(--dark-border);">
  <div class="container">
    <div style="text-align:center;max-width:560px;margin:0 auto 56px;">
      <span class="section-label">What We Do</span>
      <h2 class="section-title">Full-spectrum<br/><span class="gradient-text">AI & digital services</span></h2>
    </div>

    <div class="grid-3">
      <% services.forEach((s, i) => { %>
      <div class="service-card reveal">
        <div class="service-icon"><%= s.icon %></div>
        <h3 style="font-size:1.1rem;font-weight:700;margin-bottom:12px;"><%= s.title %></h3>
        <p style="font-size:0.9rem;color:var(--text-muted);line-height:1.8;margin-bottom:16px;"><%= s.desc %></p>
        <div class="service-tags">
          <% s.tags.forEach(tag => { %><span class="service-tag"><%= tag %></span><% }) %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Process -->
<section class="section" style="background:rgba(30,26,60,0.4);border-top:1px solid var(--dark-border);border-bottom:1px solid var(--dark-border);">
  <div class="container">
    <div style="text-align:center;max-width:520px;margin:0 auto 56px;">
      <span class="section-label">How We Work</span>
      <h2 class="section-title">Our <span class="gradient-text">proven process</span></h2>
    </div>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:24px;position:relative;">
      <!-- Connector line -->
      <div style="position:absolute;top:36px;left:10%;right:10%;height:1px;background:linear-gradient(90deg,var(--vora-purple),var(--skill-teal));opacity:0.3;z-index:0;"></div>

      <% const steps=[
        {num:'01',icon:'🔍',title:'Discovery',desc:'We audit your business, understand your goals, and identify AI opportunities.'},
        {num:'02',icon:'🗺️',title:'Roadmap',desc:'We build a clear, actionable implementation plan with timeline and KPIs.'},
        {num:'03',icon:'⚙️',title:'Build',desc:'Our team implements, tests, and iterates until the solution is production-ready.'},
        {num:'04',icon:'🚀',title:'Launch & Support',desc:'We go live, train your team, and provide ongoing support and optimisation.'},
      ]; %>
      <% steps.forEach((s,i) => { %>
      <div class="reveal" style="background:var(--dark-card);border:1px solid var(--dark-border);border-radius:var(--radius-lg);padding:28px;text-align:center;position:relative;z-index:1;">
        <div style="width:52px;height:52px;background:rgba(127,119,221,0.1);border:1px solid rgba(127,119,221,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:1.3rem;"><%= s.icon %></div>
        <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.12em;color:var(--vora-purple);margin-bottom:8px;"><%= s.num %></p>
        <h4 style="font-weight:700;margin-bottom:10px;"><%= s.title %></h4>
        <p style="font-size:0.84rem;color:var(--text-muted);line-height:1.7;"><%= s.desc %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Projects -->
<section class="section" id="projects">
  <div class="container">
    <div style="text-align:center;max-width:520px;margin:0 auto 56px;">
      <span class="section-label">Our Work</span>
      <h2 class="section-title">Projects that<br/><span class="gradient-text">moved the needle</span></h2>
    </div>

    <div style="display:flex;flex-direction:column;gap:32px;">
      <% projects.forEach((p, i) => { %>
      <div class="card reveal" style="display:grid;grid-template-columns:<%= p.youtube_id ? '1fr 1.5fr' : '1fr' %>;gap:0;overflow:hidden;">
        <% if (p.youtube_id) { %>
        <div style="position:relative;padding-bottom:56.25%;">
          <iframe src="https://www.youtube.com/embed/<%= p.youtube_id %>" frameborder="0" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;" loading="lazy"></iframe>
        </div>
        <% } %>
        <div class="card-body" style="padding:36px;">
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;">
            <% p.tags.forEach(t => { %><span class="badge badge-purple"><%= t %></span><% }) %>
          </div>
          <h3 style="font-size:1.3rem;font-weight:700;margin-bottom:8px;"><%= p.title %></h3>
          <p style="font-size:0.8rem;color:var(--text-muted);margin-bottom:14px;">Client: <span style="color:var(--text-primary);"><%= p.client %></span></p>
          <p style="color:var(--text-muted);line-height:1.8;margin-bottom:20px;"><%= p.desc %></p>
          <div style="display:flex;align-items:center;gap:10px;background:rgba(29,158,117,0.08);border:1px solid rgba(29,158,117,0.2);border-radius:var(--radius-md);padding:12px 16px;">
            <span style="color:var(--skill-teal);font-size:1.1rem;">📈</span>
            <p style="font-size:0.875rem;color:var(--skill-teal);font-weight:600;"><%= p.result %></p>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section-sm">
  <div class="container">
    <div class="cta-banner">
      <h2 class="display-md" style="margin-bottom:20px;">
        Ready to transform<br/><span class="gradient-text">your business with AI?</span>
      </h2>
      <p class="muted body-lg" style="max-width:480px;margin:0 auto 36px;">
        Let's have a free 30-minute discovery call to explore how AI can work for your business.
      </p>
      <a href="/contact" class="btn btn-primary btn-lg">Book Free Consultation →</a>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
