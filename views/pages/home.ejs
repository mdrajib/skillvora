<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- ── HERO ─────────────────────────────────────────────────────────────────── -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-glow"></div>
  <div class="hero-glow-2"></div>
  <div class="container">
    <div class="hero-content animate-fade-up">

      <div class="hero-eyebrow">
        Bangladesh's Premier &nbsp;<span>AI Education & Agency</span>
      </div>

      <h1 class="display-xl hero-title">
        Hungry to Learn.<br/>
        <em class="gradient-text"><span class="typewriter">AI Education.</span></em>
      </h1>

      <p class="hero-desc">
        Master AI, Odoo ERP, and business automation with Bangladesh's most practical training platform — then let our agency team implement it for your business.
      </p>

      <div class="hero-cta">
        <a href="/courses" class="btn btn-primary btn-lg">
          Explore Courses <span style="font-size:1.1rem">→</span>
        </a>
        <a href="/agency" class="btn btn-outline btn-lg">
          Work With Us
        </a>
      </div>

      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-number" data-count="500" data-suffix="+">500+</span>
          <span class="stat-label">Students Trained</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-count="30" data-suffix="+">30+</span>
          <span class="stat-label">Projects Delivered</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-count="10" data-suffix="+">10+</span>
          <span class="stat-label">Courses Available</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-count="98" data-suffix="%">98%</span>
          <span class="stat-label">Satisfaction Rate</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ── TRUST BAR ──────────────────────────────────────────────────────────────── -->
<div class="trust-bar">
  <div class="container">
    <div class="trust-bar-inner">
      <div class="trust-item"><span class="icon">✓</span> Official Odoo Ready Partner</div>
      <div class="trust-item" style="color:var(--dark-border);">|</div>
      <div class="trust-item"><span class="icon">🎓</span> Industry Expert Mentors</div>
      <div class="trust-item" style="color:var(--dark-border);">|</div>
      <div class="trust-item"><span class="icon">📜</span> Certified Curriculum</div>
      <div class="trust-item" style="color:var(--dark-border);">|</div>
      <div class="trust-item"><span class="icon">🤖</span> AI-Powered Learning</div>
      <div class="trust-item" style="color:var(--dark-border);">|</div>
      
    </div>
  </div>
</div>

<!-- ── ABOUT SUMMARY ──────────────────────────────────────────────────────────── -->
<section class="section">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;">

      <div class="reveal">
        <span class="section-label">About Skillvora</span>
        <h2 class="section-title" style="margin-bottom:20px;">
          We don't just teach AI.<br/>
          <span class="gradient-text">We help you devour it.</span>
        </h2>
        <p class="body-lg muted" style="margin-bottom:28px;">
          Skillvora was born from a simple belief: Bangladesh has brilliant minds that deserve world-class AI education and agency support. We bridge the gap between ambition and execution.
        </p>
        <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:32px;">
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:8px;height:8px;border-radius:50%;background:var(--vora-purple);flex-shrink:0;"></div>
            <span class="muted">Practical, hands-on training from real industry experts</span>
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:8px;height:8px;border-radius:50%;background:var(--skill-teal);flex-shrink:0;"></div>
            <span class="muted">End-to-end AI agency services for your business growth</span>
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:8px;height:8px;border-radius:50%;background:var(--hunger-amber);flex-shrink:0;"></div>
            <span class="muted">Bilingual support — English & Bangla for every learner</span>
          </div>
        </div>
        <a href="/about" class="btn btn-secondary">Read Our Story →</a>
      </div>

      <div class="reveal" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div class="service-card" style="padding:24px;">
          <div class="service-icon">🎓</div>
          <h4 style="font-size:1rem;margin-bottom:8px;">Education</h4>
          <p style="font-size:0.85rem;color:var(--text-muted);">Professional AI & ERP courses for real-world results</p>
        </div>
        <div class="service-card" style="padding:24px;margin-top:24px;">
          <div class="service-icon">🤖</div>
          <h4 style="font-size:1rem;margin-bottom:8px;">AI Agency</h4>
          <p style="font-size:0.85rem;color:var(--text-muted);">Implement AI solutions that transform your business</p>
        </div>
        <div class="service-card" style="padding:24px;">
          <div class="service-icon">⚙️</div>
          <h4 style="font-size:1rem;margin-bottom:8px;">Odoo ERP</h4>
          <p style="font-size:0.85rem;color:var(--text-muted);">Official Odoo partner for implementation & support</p>
        </div>
        <div class="service-card" style="padding:24px;margin-top:24px;">
          <div class="service-icon">📈</div>
          <h4 style="font-size:1rem;margin-bottom:8px;">Consulting</h4>
          <p style="font-size:0.85rem;color:var(--text-muted);">Strategy-first digital transformation advisory</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ── FEATURED COURSES ────────────────────────────────────────────────────────── -->
<section class="section" style="background:rgba(30,26,60,0.3);border-top:1px solid var(--dark-border);border-bottom:1px solid var(--dark-border);">
  <div class="container">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:48px;gap:20px;flex-wrap:wrap;">
      <div>
        <span class="section-label">Featured Courses</span>
        <h2 class="section-title">
          Learn from the<br/><span class="gradient-text">best in Bangladesh</span>
        </h2>
      </div>
      <a href="/courses" class="btn btn-outline">View All Courses →</a>
    </div>

    <div class="grid-3">
      <% featuredCourses.forEach((course, i) => { %>
      <div class="card course-card reveal" style="animation-delay:<%=i*0.1%>s">
        <div class="card-img-placeholder">
          <% const icons = {'ERP':'⚙️','AI':'🤖','DEFAULT':'📚'}; %>
          <%= icons[course.category] || icons.DEFAULT %>
        </div>
        <div class="card-body">
          <div class="course-meta">
            <span class="badge badge-purple"><%= course.category %></span>
            <span class="badge badge-gray"><%= course.level %></span>
          </div>
          <h3 style="font-size:1.05rem;font-weight:700;margin-bottom:10px;line-height:1.4;">
            <%= course.title %>
          </h3>
          <p style="font-size:0.875rem;color:var(--text-muted);margin-bottom:16px;line-height:1.7;">
            <%= course.short_desc %>
          </p>
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;font-size:0.8rem;color:var(--text-muted);">
            <span>⏱ <%= course.duration %></span>
            <span>👤 <%= course.mentor %></span>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <span style="font-size:1.1rem;font-weight:700;color:var(--vora-purple);font-family:var(--font-display);">
              <%= course.price %>
            </span>
            <a href="/courses/<%= course.slug %>" class="btn btn-primary btn-sm">Enroll Now</a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ── FEATURED MENTORS ────────────────────────────────────────────────────────── -->
<section class="section">
  <div class="container">
    <div style="text-align:center;max-width:560px;margin:0 auto 48px;">
      <span class="section-label">Our Mentors</span>
      <h2 class="section-title">
        Learn from <span class="gradient-text">industry experts</span>
      </h2>
      <p class="muted body-lg">Real practitioners with years of hands-on experience, not just theory.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:28px;max-width:720px;margin:0 auto;">
      <% featuredMentors.forEach((mentor, i) => { %>
      <div class="mentor-card reveal" style="animation-delay:<%=i*0.15%>s">
        <div class="mentor-photo-placeholder">👨‍💻</div>
        <div class="mentor-body">
          <p class="mentor-expertise"><%= mentor.expertise %></p>
          <h3 style="font-size:1.1rem;font-weight:700;margin-bottom:6px;"><%= mentor.name %></h3>
          <p style="font-size:0.82rem;color:var(--vora-purple);margin-bottom:12px;font-weight:500;"><%= mentor.title %></p>
          <p style="font-size:0.85rem;color:var(--text-muted);line-height:1.7;margin-bottom:20px;"><%= mentor.short_bio %></p>
          <a href="/mentors/<%= mentor.slug %>" class="btn btn-secondary btn-sm" style="width:100%;justify-content:center;">View Profile →</a>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ── AI AGENCY SERVICES ─────────────────────────────────────────────────────── -->
<section class="section" style="background:rgba(30,26,60,0.3);border-top:1px solid var(--dark-border);border-bottom:1px solid var(--dark-border);">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1.5fr;gap:64px;align-items:center;">

      <div class="reveal">
        <span class="section-label">AI Agency</span>
        <h2 class="section-title" style="margin-bottom:20px;">
          We build AI solutions<br/><span class="gradient-text">that actually work</span>
        </h2>
        <p class="muted" style="margin-bottom:32px;line-height:1.8;">
          From AI consulting and Odoo ERP implementation to custom software and digital transformation — we deliver end-to-end solutions for businesses across Bangladesh.
        </p>
        <a href="/agency" class="btn btn-teal">See Our Work →</a>
      </div>

      <div class="reveal" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <% const services = [
          {icon:'🤖',title:'AI Consulting',desc:'Strategy & implementation roadmaps'},
          {icon:'⚙️',title:'Odoo ERP',desc:'Full-cycle implementation & support'},
          {icon:'🔗',title:'Integrations',desc:'APIs, bots & automation workflows'},
          {icon:'📊',title:'BI & Analytics',desc:'Dashboards & AI-driven insights'},
          {icon:'🌐',title:'Digital Transform.',desc:'Cloud & process modernisation'},
          {icon:'📱',title:'Custom Software',desc:'Web & mobile app development'},
        ]; %>
        <% services.forEach((s,i) => { %>
        <div class="service-card" style="padding:20px;">
          <div style="font-size:1.6rem;margin-bottom:10px;"><%= s.icon %></div>
          <h4 style="font-size:0.9rem;font-weight:700;margin-bottom:6px;"><%= s.title %></h4>
          <p style="font-size:0.78rem;color:var(--text-muted);"><%= s.desc %></p>
        </div>
        <% }) %>
      </div>

    </div>
  </div>
</section>

<!-- ── TESTIMONIALS ───────────────────────────────────────────────────────────── -->
<section class="section">
  <div class="container">
    <div style="text-align:center;max-width:520px;margin:0 auto 48px;">
      <span class="section-label">Testimonials</span>
      <h2 class="section-title">
        What our <span class="gradient-text">community says</span>
      </h2>
    </div>

    <div class="grid-4">
      <% testimonials.forEach((t, i) => { %>
      <div class="testimonial-card reveal" style="animation-delay:<%=i*0.1%>s">
        <div class="stars">★★★★★</div>
        <p class="testimonial-text">"<%= t.text %>"</p>
        <div class="testimonial-author">
          <div class="author-avatar"><%= t.avatar %></div>
          <div>
            <p class="author-name"><%= t.name %></p>
            <p class="author-role"><%= t.role %></p>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ── YOUTUBE SECTION ────────────────────────────────────────────────────────── -->
<section class="section" style="background:rgba(30,26,60,0.3);border-top:1px solid var(--dark-border);border-bottom:1px solid var(--dark-border);">
  <div class="container">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:48px;gap:20px;flex-wrap:wrap;">
      <div>
        <span class="section-label">YouTube</span>
        <h2 class="section-title">
          Free content on <span class="gradient-text">our channel</span>
        </h2>
      </div>
      <a href="https://youtube.com/@skillvora" target="_blank" rel="noopener" class="btn btn-outline">
        Visit Channel ↗
      </a>
    </div>

    <div class="grid-3">
      <% const ytVideos = [
        {id:'dQw4w9WgXcQ', title:'Introduction to Odoo 17 — Full Overview', views:'2.1K'},
        {id:'dQw4w9WgXcQ', title:'ChatGPT Prompt Engineering for Beginners', views:'3.4K'},
        {id:'dQw4w9WgXcQ', title:'AI for Business — How to Get Started Today', views:'1.8K'},
      ]; %>
      <% ytVideos.forEach((v, i) => { %>
      <div class="card reveal" style="animation-delay:<%=i*0.1%>s">
        <div style="position:relative;padding-bottom:56.25%;overflow:hidden;">
          <iframe
            src="https://www.youtube.com/embed/<%= v.id %>"
            title="<%= v.title %>"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            style="position:absolute;top:0;left:0;width:100%;height:100%;"
            loading="lazy">
          </iframe>
        </div>
        <div class="card-body">
          <h4 style="font-size:0.95rem;font-weight:600;margin-bottom:8px;"><%= v.title %></h4>
          <p style="font-size:0.8rem;color:var(--text-muted);">👁 <%= v.views %> views</p>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ── CONTACT CTA ────────────────────────────────────────────────────────────── -->
<section class="section">
  <div class="container">
    <div class="cta-banner reveal">
      <span class="section-label" style="margin-bottom:24px;">Get Started Today</span>
      <h2 class="display-md" style="margin-bottom:20px;">
        Ready to devour<br/><span class="gradient-text">skills & grow with AI?</span>
      </h2>
      <p class="muted body-lg" style="max-width:480px;margin:0 auto 40px;">
        Join 500+ students and businesses across Bangladesh who are already ahead of the curve with Skillvora.
      </p>
      <div style="display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;">
        <a href="/courses" class="btn btn-primary btn-lg">Start Learning →</a>
        <a href="/contact" class="btn btn-outline btn-lg">Talk to Us</a>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
